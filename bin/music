#!/bin/sh

# mpv player function — avoids storing a command string (quoting nightmare)
play() {
  mpv --quiet \
    --msg-level=cplayer=no,ffmpeg=no,ao=no,ad=no,display-tags=no \
    --no-resume-playback \
    --http-header-fields="Icy-MetaData:1" \
    --http-header-fields="User-Agent: mpv/0.37.0" \
    "$@"
}

XDG_CACHE_HOME=${XDG_CACHE_HOME:-$HOME/.cache}
STATIONS=${STATIONS:-$HOME/stations.txt}

# == stations.txt example ==
# sleepbot=http://www.sleepbot.com/ambience/cgi/listen.cgi/listen.pls
# soma
# tilderadio=https://azuracast.tilderadio.org/radio/8000/320k.ogg

# Safe lookup: exact-match station name, no regex injection.
# Only matches lines containing '=' (plain URL entries).
lookup_station() {
  _lookup_name="$1"
  while IFS='=' read -r key value; do
    [ -z "$key" ] && continue
    case "$key" in \#*|+*) continue ;; esac
    if [ "$key" = "$_lookup_name" ]; then
      printf '%s' "$value"
      return 0
    fi
  done < "$STATIONS"
  return 1
}

# ── Special handlers ─────────────────────────────────────────────────
# Add a new handler by defining handler_<name> and adding +<name> to stations.txt.

handler_soma() {
  _soma_cache="${XDG_CACHE_HOME}/soma-stations.txt"
  if [ -f "$_soma_cache" ] && [ "$(find "$_soma_cache" -mmin +$((60*24)) 2>/dev/null)" ]; then
    rm "$_soma_cache"
  fi
  if [ ! -f "$_soma_cache" ]; then
    curl -s https://somafm.com/channels.json \
      | jq -r '.channels[] | [.title, .playlists[0].url] | @tsv' \
      > "$_soma_cache"
  fi
  _soma_name="$(cut -f1 "$_soma_cache" | fzf --select-1 --exit-0)"
  if [ -n "$_soma_name" ]; then
    _soma_url="$(awk -F'\t' -v k="$_soma_name" '$1 == k { print $2; exit }' "$_soma_cache")"
    [ -n "$_soma_url" ] && play "$_soma_url"
  fi
}

# ── Main ─────────────────────────────────────────────────────────────

# Read stations.txt and get list of stations to browse
if [ -z "$1" ]; then
  select="$(grep -v '^#' "$STATIONS" | grep -v '^$' | cut -d '=' -f 1 | sed 's/^+//' | fzf \
    --select-1 \
    --exit-0)"
else
  select="$1"
fi

# Normalize: strip leading + so 'music +soma' and 'music soma' both work
select="${select#+}"

if [ -n "$select" ]; then

  # Special handler? (try handler_<name>)
  _handler_name="handler_${select}"
  if type "$_handler_name" >/dev/null 2>&1; then
    "$_handler_name"

  else
    # Plain URL entry
    stream="$(lookup_station "$select")"
    [ -n "$stream" ] && play "$stream"
  fi
fi
