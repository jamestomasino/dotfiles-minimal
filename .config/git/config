[user]
  name = James Tomasino
  email = james@tomasino.org
  signingkey = 09DDD7DF

[sendemail]
  smtpserver = mail.messagingengine.com
  smtpuser = james@tomasino.org
  smtpencryption = tls
  smtpserverport = 587
  annotate = yes

[credential]
  helper = cache --timeout=3600

[github]
  user = jamestomasino

[gpg]
  program = gpg

[init]
  defaultBranch = main

[tag]
  gpgsign = true
  forceSignAnnotated = true
[core]
  whitespace = trailing-space, space-before-tab, cr-at-eol
  editor = vim
  autocrlf = input
  pager = delta

[delta]
  syntax-theme = Monokai Extended
  side-by-side = true
  colorMoved = default

[interactive]
  diffFilter = delta --color-only

[diff]
  algorithm = histogram

[merge]
  stat = true
  log = true
  tool = fugitive
  conflictstyle = zdiff3

[mergetool]
  keepBackup = false
  prompt = false

[mergetool "fugitive"]
  cmd = vim -f -c \"Gvdiffsplit!\" \"$MERGED\"

[rerere]
  enabled = true

[push]
  followTags = true
  default = simple
  autoSetupRemote = true

[fetch]
  prune = true
  pruneTags = true

[pull]
  rebase = true

[rebase]
  autosquash = true
  autoStash = true

[color]
  diff = auto
  status = auto
  branch = auto
  interactive = auto
  ui = auto

[color "branch"]
  current = yellow reverse
  local = yellow
  remote = green

[color "status"]
  added = yellow
  changed = green
  untracked = cyan

[safe]
  directory = /var/cosmic
  directory = /opt/cosmic-gemini

[notes]
  displayRef = refs/notes/*

[alias]
  lg = log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr)%Creset' --abbrev-commit --date=relative
  lp = log --pretty=format:'%Cblue%h%Creset %Cgreen%<(15)%ad%Creset | %s%d [%C(yellow)%an%Creset] %C(cyan)%d%Creset' --date=relative --no-merges
  latestremote = !git for-each-ref refs/remotes/ --format="%(color:green)%(committerdate:short)%(color:reset) %(color:yellow)%(refname:short)%(color:reset)" --sort=-committerdate
  rawlog = log --format="format:commit %H%nAuthor:%an%n%n%B%n"
  branchage = for-each-ref --sort=committerdate refs/heads --format=%(color:green)%(committerdate:iso8601)%(color:reset) %(color:blue)%(committerdate:relative)%(color:reset) %(refname:short)
  branchageall = for-each-ref --sort=committerdate refs/remotes --format=%(color:green)%(committerdate:iso8601)%(color:reset) %(color:blue)%(committerdate:relative)%(color:reset) %(refname:short)
  ls-ignored = ls-files --exclude-standard --ignored --others
  tags = tag -n1 -l
